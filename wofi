window {
    margin: 0px;
    border: 2px solid #aabcf7;
    background-color: rgba(30, 31, 72, 0.8);
    border-radius: 6px;
}

#input {
    margin: 8px;
    padding: 10px;
    background-color: #33357c;
    border: none;
    color: #e2eafd;
    font-size: 16px;
    border-radius: 6px;
}

#entry {
    padding: 10px;
    margin: 5px;
    background-color: transparent;
    color: #ffffff;
    border-radius: 6px;
}

#entry:selected {
    background-color: #4f4fdc;
    color: #e5e9f4;
}
